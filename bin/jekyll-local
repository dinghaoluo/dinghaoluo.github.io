#!/usr/bin/env bash
set -euo pipefail

repo_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
ruby_dir="${RUBY_ROOT:-$HOME/.rubies/ruby-3.1.3}"
bundle_bin="$ruby_dir/bin/bundle"

if [ ! -x "$bundle_bin" ]; then
  bundle_bin="$(command -v bundle)"
fi

cd "$repo_dir"
exec "$bundle_bin" exec jekyll "$@" --config _config.yml,_config_local.yml
